<div class="mx-auto flex items-center justify-center">
  <div class="min-w-md bg-white border border-slate-200 rounded-xl shadow-sm p-8">
    <div class="text-center mb-6">
      <%= image_tag "logo.svg", alt: "Clever logo", class: "h-10 mx-auto mb-3" %>
      <h1 class="text-2xl font-semibold text-slate-900">Sign in</h1>
      <p class="text-sm text-slate-600 mt-1">Photo Gallery Access</p>
    </div>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full px-3 py-2 text-base bg-gray-50 rounded-md border border-slate-300 focus:border-blue-600" %>
      </div>
      <div>
        <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password,
              class: "w-full px-3 py-2 text-base bg-gray-50 rounded-md border border-slate-300 focus:border-blue-600" %>
      </div>
      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded-sm border border-slate-300 bg-gray-50 accent-blue-600" %>
          <%= f.label :remember_me, class: "text-sm text-slate-700" %>
        </div>
      <% end %>
      <%= f.submit "Sign in",
            class: "w-full inline-flex justify-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" %>
    <% end %>
  </div>
</div>
